//@version=6
indicator("SPX - SMA8 Zonas ±8/15/25", overlay=true)

length = input.int(8, "SMA")
d1 = input.float(8.0, "Primer nivel")
d2 = input.float(15.0, "Segundo nivel")
d3 = input.float(25.0, "Tercer nivel")

smaColor = input.color(color.yellow, "Color SMA")
upperZone1Color = input.color(color.rgb(198,239,206), "Zona +8 a +15")
upperZone2Color = input.color(color.rgb(99,190,123), "Zona +15 a +25")
lowerZone1Color = input.color(color.rgb(255,199,206), "Zona -8 a -15")
lowerZone2Color = input.color(color.rgb(248,105,107), "Zona -15 a -25")
zoneTransparency = input.int(25, "Transparencia", minval=0, maxval=100)

sma8 = ta.sma(close, length)

up8 = sma8 + d1
up15 = sma8 + d2
up25 = sma8 + d3

dn8 = sma8 - d1
dn15 = sma8 - d2
dn25 = sma8 - d3

plot(sma8, color=smaColor, linewidth=2, title="SMA 8")

pUp8 = plot(up8, color=color.rgb(165,214,167), linewidth=1, title="+8")
pUp15 = plot(up15, color=color.rgb(102,187,106), linewidth=1, title="+15")
pUp25 = plot(up25, color=color.rgb(56,142,60), linewidth=1, title="+25")

pDn8 = plot(dn8, color=color.rgb(239,154,154), linewidth=1, title="-8")
pDn15 = plot(dn15, color=color.rgb(239,83,80), linewidth=1, title="-15")
pDn25 = plot(dn25, color=color.rgb(198,40,40), linewidth=1, title="-25")

fill(pUp8, pUp15, color=color.new(upperZone1Color, zoneTransparency), title="Zona +8 a +15")
fill(pUp15, pUp25, color=color.new(upperZone2Color, zoneTransparency), title="Zona +15 a +25")
fill(pDn8, pDn15, color=color.new(lowerZone1Color, zoneTransparency), title="Zona -8 a -15")
fill(pDn15, pDn25, color=color.new(lowerZone2Color, zoneTransparency), title="Zona -15 a -25")

//@version=6
indicator("SPX - SMA8 Zonas por puntos o porcentaje", overlay=true)

usePercentage = input.bool(true, "Usar porcentajes", group="Modo de cálculo")

length = input.int(8, "Periodo SMA", minval=1, group="Media móvil")

pointLevel1 = input.float(8.0, "Nivel 1", minval=0.0, step=0.25, inline="points", group="Distancias en puntos")
pointLevel2 = input.float(15.0, "Nivel 2", minval=0.0, step=0.25, inline="points", group="Distancias en puntos")
pointLevel3 = input.float(25.0, "Nivel 3", minval=0.0, step=0.25, inline="points", group="Distancias en puntos")

percentLevel1 = input.float(0.15, "Nivel 1 (%)", minval=0.0, step=0.01, inline="percent", group="Distancias porcentuales")
percentLevel2 = input.float(0.20, "Nivel 2 (%)", minval=0.0, step=0.01, inline="percent", group="Distancias porcentuales")
percentLevel3 = input.float(0.35, "Nivel 3 (%)", minval=0.0, step=0.01, inline="percent", group="Distancias porcentuales")

smaColor = input.color(color.yellow, "SMA 8", group="Colores")
upperZone1Color = input.color(color.rgb(198, 239, 206), "Zona superior 1", group="Colores")
upperZone2Color = input.color(color.rgb(99, 190, 123), "Zona superior 2", group="Colores")
lowerZone1Color = input.color(color.rgb(255, 199, 206), "Zona inferior 1", group="Colores")
lowerZone2Color = input.color(color.rgb(248, 105, 107), "Zona inferior 2", group="Colores")
zoneTransparency = input.int(25, "Transparencia", minval=0, maxval=100, group="Colores")

sma8 = ta.sma(close, length)

distance1 = usePercentage ? sma8 * percentLevel1 / 100.0 : pointLevel1
distance2 = usePercentage ? sma8 * percentLevel2 / 100.0 : pointLevel2
distance3 = usePercentage ? sma8 * percentLevel3 / 100.0 : pointLevel3

up1 = sma8 + distance1
up2 = sma8 + distance2
up3 = sma8 + distance3

dn1 = sma8 - distance1
dn2 = sma8 - distance2
dn3 = sma8 - distance3

plot(sma8, color=smaColor, linewidth=2, title="SMA 8")

pUp1 = plot(up1, color=color.rgb(165, 214, 167), linewidth=1, title="Nivel superior 1")
pUp2 = plot(up2, color=color.rgb(102, 187, 106), linewidth=1, title="Nivel superior 2")
pUp3 = plot(up3, color=color.rgb(56, 142, 60), linewidth=1, title="Nivel superior 3")

pDn1 = plot(dn1, color=color.rgb(239, 154, 154), linewidth=1, title="Nivel inferior 1")
pDn2 = plot(dn2, color=color.rgb(239, 83, 80), linewidth=1, title="Nivel inferior 2")
pDn3 = plot(dn3, color=color.rgb(198, 40, 40), linewidth=1, title="Nivel inferior 3")

fill(pUp1, pUp2, color=color.new(upperZone1Color, zoneTransparency), title="Zona superior 1")
fill(pUp2, pUp3, color=color.new(upperZone2Color, zoneTransparency), title="Zona superior 2")
fill(pDn1, pDn2, color=color.new(lowerZone1Color, zoneTransparency), title="Zona inferior 1")
fill(pDn2, pDn3, color=color.new(lowerZone2Color, zoneTransparency), title="Zona inferior 2")

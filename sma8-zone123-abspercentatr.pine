//@version=6
indicator("SMA8 Extension Zones (Points • % • ATR)", overlay=true)

calculationMode = input.string("Porcentaje", "Modo de cálculo", options=["Porcentaje", "Puntos", "ATR"], group="Modo de cálculo")

smaLength = input.int(8, "Periodo SMA", minval=1, group="Media móvil")

pointLevel1 = input.float(8.0, "Nivel 1", minval=0.0, step=0.25, inline="points", group="Distancias en puntos")
pointLevel2 = input.float(15.0, "Nivel 2", minval=0.0, step=0.25, inline="points", group="Distancias en puntos")
pointLevel3 = input.float(25.0, "Nivel 3", minval=0.0, step=0.25, inline="points", group="Distancias en puntos")

percentLevel1 = input.float(0.15, "Nivel 1 (%)", minval=0.0, step=0.01, inline="percent", group="Distancias porcentuales")
percentLevel2 = input.float(0.20, "Nivel 2 (%)", minval=0.0, step=0.01, inline="percent", group="Distancias porcentuales")
percentLevel3 = input.float(0.35, "Nivel 3 (%)", minval=0.0, step=0.01, inline="percent", group="Distancias porcentuales")

atrLength = input.int(14, "Periodo ATR", minval=1, group="Configuración ATR")
atrMultiplier1 = input.float(0.5, "Multiplicador 1", minval=0.0, step=0.1, inline="atr", group="Configuración ATR")
atrMultiplier2 = input.float(1.0, "Multiplicador 2", minval=0.0, step=0.1, inline="atr", group="Configuración ATR")
atrMultiplier3 = input.float(1.5, "Multiplicador 3", minval=0.0, step=0.1, inline="atr", group="Configuración ATR")

smaColor = input.color(color.yellow, "SMA 8", group="Colores")
upperZone1Color = input.color(color.rgb(198, 239, 206), "Zona superior 1", group="Colores")
upperZone2Color = input.color(color.rgb(99, 190, 123), "Zona superior 2", group="Colores")
lowerZone1Color = input.color(color.rgb(255, 199, 206), "Zona inferior 1", group="Colores")
lowerZone2Color = input.color(color.rgb(248, 105, 107), "Zona inferior 2", group="Colores")
zoneTransparency = input.int(25, "Transparencia", minval=0, maxval=100, group="Colores")

sma8 = ta.sma(close, smaLength)
atrValue = ta.atr(atrLength)

distance1 = switch calculationMode
    "Porcentaje" => sma8 * percentLevel1 / 100.0
    "Puntos" => pointLevel1
    "ATR" => atrValue * atrMultiplier1

distance2 = switch calculationMode
    "Porcentaje" => sma8 * percentLevel2 / 100.0
    "Puntos" => pointLevel2
    "ATR" => atrValue * atrMultiplier2

distance3 = switch calculationMode
    "Porcentaje" => sma8 * percentLevel3 / 100.0
    "Puntos" => pointLevel3
    "ATR" => atrValue * atrMultiplier3

upperLevel1 = sma8 + distance1
upperLevel2 = sma8 + distance2
upperLevel3 = sma8 + distance3

lowerLevel1 = sma8 - distance1
lowerLevel2 = sma8 - distance2
lowerLevel3 = sma8 - distance3

plot(sma8, color=smaColor, linewidth=2, title="SMA 8")

pUpper1 = plot(upperLevel1, color=color.rgb(165, 214, 167), linewidth=1, title="Nivel superior 1")
pUpper2 = plot(upperLevel2, color=color.rgb(102, 187, 106), linewidth=1, title="Nivel superior 2")
pUpper3 = plot(upperLevel3, color=color.rgb(56, 142, 60), linewidth=1, title="Nivel superior 3")

pLower1 = plot(lowerLevel1, color=color.rgb(239, 154, 154), linewidth=1, title="Nivel inferior 1")
pLower2 = plot(lowerLevel2, color=color.rgb(239, 83, 80), linewidth=1, title="Nivel inferior 2")
pLower3 = plot(lowerLevel3, color=color.rgb(198, 40, 40), linewidth=1, title="Nivel inferior 3")

fill(pUpper1, pUpper2, color=color.new(upperZone1Color, zoneTransparency), title="Zona superior 1")
fill(pUpper2, pUpper3, color=color.new(upperZone2Color, zoneTransparency), title="Zona superior 2")
fill(pLower1, pLower2, color=color.new(lowerZone1Color, zoneTransparency), title="Zona inferior 1")
fill(pLower2, pLower3, color=color.new(lowerZone2Color, zoneTransparency), title="Zona inferior 2")
